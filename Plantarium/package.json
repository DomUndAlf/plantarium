{
  "name": "plantarium-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start-front": "cd FE && npm run dev",
    "start-back": "cd BE && npm run dev:local",
    "start": "npm-run-all --parallel start-front start-back",
    "dev:frontend": "cd FE && npm run dev",
    "dev:auth": "cd aServices/auth && npm run dev",
    "dev:plants": "cd aServices/plants && npm run dev",
    "dev:beds": "cd aServices/beds && npm run dev",
    "dev:struct": "cd aServices/struct && npm run dev",
    "dev:weather": "cd aServices/weather && npm run dev",
    "dev:all": "npm-run-all --parallel dev:frontend dev:auth dev:plants dev:beds dev:struct dev:weather ",
    "build:frontend": "cd FE && npm run build",
    "build:auth": "cd aServices/auth && npm run build",
    "build:plants": "cd aServices/plants && npm run build",   
    "build:beds": "cd aServices/beds && npm run build",
    "build:struct": "cd aServices/struct && npm run build",
    "build:weather": "cd aServices/weather && npm run build",



    "build:all": "npm-run-all build:frontend build:auth build:plants build:beds build:struct build:weather",
    "format:frontend": "cd FE && npx prettier --write .",
    "format:backend": "cd BE && npx prettier --write .",
    "format:all": "npm run format:frontend && npm run format:backend"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "dependencies": {
    "@prisma/client": "^6.15.0"
  }
}

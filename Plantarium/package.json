{
    "scripts": {
        "start-front": "cd FE && npm run dev",
        "start-back": "cd BE && npm start",
        "start": "npm-run-all --parallel start-front start-back",
        "format-back": "cd BE && npx prettier",
        "format-front": "cd FE && npx prettier",
        "format": "npm run format-front && npm run format-back",
        "dev:frontend": "cd FE && npm run dev:local",
        "dev:backend": "cd BE && npm run dev:local",
        "dev:all": "run-p dev:frontend dev:backend"
    },
    "devDependencies": {
        "npm-run-all": "^4.1.5"
    }
}

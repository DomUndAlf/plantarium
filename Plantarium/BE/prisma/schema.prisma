generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model bed_plants {
  bed_id        Int
  plant_id      Int
  quantity      Int
  planting_date DateTime @db.Date
  beds          beds     @relation(fields: [bed_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "bed_plants_ibfk_1")
  plants        plants   @relation(fields: [plant_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "bed_plants_ibfk_2")

  @@id([bed_id, plant_id])
  @@index([plant_id], map: "plant_id")
}

model beds {
  id         Int          @id @default(autoincrement())
  user_id    Int
  x_position Float        @db.Float
  y_position Float        @db.Float
  width      Float        @db.Float
  height     Float        @db.Float
  bed_plants bed_plants[]
  users      users        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "beds_ibfk_1")

  @@index([user_id], map: "user_id")
}

model individual_plants {
  user_id       Int
  plant_id      Int
  x_position    Float    @db.Float
  y_position    Float    @db.Float
  planting_date DateTime @db.Date
  watered       Boolean? @default(false)
  users         users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "individual_plants_ibfk_1")
  plants        plants   @relation(fields: [plant_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "individual_plants_ibfk_2")

  @@id([user_id, plant_id, x_position, y_position])
  @@index([plant_id], map: "plant_id")
}

model plant_types {
  id     Int      @id @default(autoincrement())
  name   String   @unique(map: "name") @db.VarChar(255)
  plants plants[]
}

model plants {
  id                  Int                 @id @default(autoincrement())
  name                String              @db.VarChar(255)
  type_id             Int
  growth_type         plants_growth_type
  edible              Boolean?            @default(false)
  watering_interval   Int                 @default(3)
  bloom_start_month   Int?
  bloom_end_month     Int?
  harvest_start_month Int?
  harvest_end_month   Int?
  watered             Boolean?     @default(false)
  bed_plants          bed_plants[]
  individual_plants   individual_plants[]
  plant_types         plant_types         @relation(fields: [type_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "plants_ibfk_1")

  @@index([type_id], map: "type_id")
}

model surfaces {
  id         Int           @id @default(autoincrement())
  user_id    Int
  type       surfaces_type
  x_position Float         @db.Float
  y_position Float         @db.Float
  width      Float         @db.Float
  height     Float         @db.Float
  users      users         @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "surfaces_ibfk_1")
  
  @@index([user_id], map: "user_id")
}

model users {
  id                   Int                 @id @default(autoincrement())
  shibboleth_id        String              @unique(map: "shibboleth_id") @db.VarChar(255)
  name                 String?             @db.VarChar(255)
  location             String?             @db.VarChar(255)
  width                Float?              @db.Float
  height               Float?              @db.Float
  background_image_url String?             @db.VarChar(255)
  beds                 beds[]
  individual_plants    individual_plants[]
  surfaces             surfaces[]
}

enum surfaces_type {
  path
  terrace
  bed
  building
}

enum plants_growth_type {
  bed
  single
}

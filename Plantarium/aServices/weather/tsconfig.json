{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "outDir": "dist",
    "rootDir": "../../",        // erweitert den Bereich
    "baseUrl": "../../",
    "paths": {
      "@shared/*": ["../shared/*"] // Alias für shared
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src", "../shared"],
  "exclude": ["node_modules"]
}

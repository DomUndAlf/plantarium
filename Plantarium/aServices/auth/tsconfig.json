{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
       "rootDir": "../../",        // erweitert den Bereich
    "baseUrl": "../../",
    "paths": {
      "@shared/*": ["shared/*"] // Alias für shared
    },
    "outDir": "dist",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "strict": true
  },
  "include": ["src"]
}
